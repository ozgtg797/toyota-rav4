{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": ".scripts-out",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "downlevelIteration": true
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts"]
}
